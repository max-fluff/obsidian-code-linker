{
  "id": "javascript",
  "name": "JavaScript",
  "extensions": [".js", ".jsx", ".mjs", ".cjs"],
  "patterns": [
    {
      "re": "^\\s*(?:export\\s+)?(?:default\\s+)?class\\s+([A-Za-z_$][\\w$]*)",
      "kind": "class",
      "nameGroup": 1
    },
    {
      "re": "^\\s*(?:export\\s+)?(?:async\\s+)?function\\s+([A-Za-z_$][\\w$]*)",
      "kind": "function",
      "nameGroup": 1
    }
  ]
}
