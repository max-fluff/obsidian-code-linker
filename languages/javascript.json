{
  "id": "javascript",
  "name": "JavaScript",
  "extensions": [".js", ".jsx", ".mjs", ".cjs"],
  "patterns": [
    {
      "re": "^\\s*(?:export\\s+)?(?:default\\s+)?class\\s+([A-Za-z_$][\\w$]*)",
      "kind": "class",
      "nameGroup": 1
    },
    {
      "re": "^\\s*(?:export\\s+)?(?:default\\s+)?(?:async\\s+)?function\\s+([A-Za-z_$][\\w$]*)",
      "kind": "function",
      "nameGroup": 1
    },
    {
      "re": "^\\s*(?:export\\s+)?(?:default\\s+)?(?:const|let|var)\\s+([A-Za-z_$][\\w$]*)\\s*=\\s*(?:async\\s+)?(?:function\\b|\\(?[A-Za-z_$)][^=;]*=>)",
      "kind": "function",
      "nameGroup": 1
    }
  ]
}
